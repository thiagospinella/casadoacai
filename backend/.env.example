# Banco de dados (Neon — região sa-east-1 recomendada)
DATABASE_URL="postgresql://user:password@host/casadoacai?sslmode=require"

# Auth
JWT_SECRET="troque-esse-segredo-em-producao-min-32-chars"

# Servidor
PORT=3001
NODE_ENV=development
TZ=America/Sao_Paulo

# CORS — origem permitida (frontend)
CORS_ORIGIN="http://localhost:5173"

# Web Push (gerar com: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@casadoacai.com"
